<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Sales Dashboard - KIKO MILANO</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/admin.css">
    <link rel="stylesheet" href="/sales.css">
</head>
<body>

    <div class="admin-top-bar">
        <span>KIKO MILANO BACK OFFICE &bull; CENTRAL CONTROL PANEL</span>
    </div>

    <header class="admin-site-header">
        <div class="header-container">
            <div class="header-side-left">
                <span class="admin-badge-indicator">SYSTEM ADMIN</span>
            </div>
            
            <div class="admin-logo">
                <img src="/Logo.webp" alt="KIKO Milano">
            </div>

            <div class="header-side-right">
                <a href="/admin" class="return-store-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                    BACK TO DASHBOARD
                </a>
            </div>
        </div>
    </header>

    <div class="dashboard-action-bar">
        <div class="title-block">
            <h1 style="display: flex; align-items: center;">
                SALES METRICS 
                <span class="live-indicator-wrapper">
                    <div class="pulse-dot"></div> LIVE
                </span>
            </h1>
            <p>REAL-TIME PERFORMANCE TRACKING</p>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <span class="stat-title">Total Orders</span>
                <span class="stat-value" id="live-total-orders">--</span>
            </div>
            <div class="stat-icon-wrapper">📦</div>
        </div>
        
        <div class="stat-card highlighted-card">
            <div class="stat-info">
                <span class="stat-title">Total Revenue</span>
                <span class="stat-value" id="live-total-revenue">Rs. 0</span>
            </div>
            <div class="stat-icon-wrapper">💎</div>
        </div>
    </div>

    <div class="table-container">
        <h3 style="margin-bottom: 20px; font-size: 14px; font-weight: 700; letter-spacing: 2px;">RECENT TRANSACTIONS</h3>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Date & Time</th>
                </tr>
            </thead>
            <tbody id="recent-orders-body">
                <tr>
                    <td colspan="5" style="text-align: center; padding: 30px;">
                        <span style="color: #888; font-size: 12px; letter-spacing: 1px;">Establishing secure connection to live database...</span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            function fetchLiveSalesData() {
                $.getJSON('/api/v1/sales-data', function(response) {
                    if(response.success) {
                        const data = response.data;
                        
                        $('#live-total-orders').fadeOut(150, function() {
                            $(this).text(data.totalOrders).fadeIn(150);
                        });
                        
                        $('#live-total-revenue').fadeOut(150, function() {
                            $(this).text('Rs. ' + data.totalRevenue.toLocaleString()).fadeIn(150);
                        });

                        const tableBody = $('#recent-orders-body');
                        tableBody.empty();

                        if(data.recentOrders.length === 0) {
                            tableBody.append('<tr><td colspan="5" style="text-align: center; font-weight: 500;">No transactions recorded yet.</td></tr>');
                            return;
                        }

                        data.recentOrders.forEach(order => {
                            const orderDate = new Date(order.createdAt).toLocaleString('en-US', { 
                                month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' 
                            });
                            const shortId = order._id.substring(0, 8).toUpperCase();
                            const customerName = order.customer ? order.customer.name : 'Guest User';
                            const statusClass = order.status === 'Processing' ? 'status-processing' : 'status-delivered';

                            const rowHtml = `
                                <tr>
                                    <td style="font-weight: 700; font-family: monospace; font-size: 14px;">#${shortId}</td>
                                    <td style="font-weight: 600;">${customerName}</td>
                                    <td style="font-weight: 700;">Rs. ${order.totalAmount.toLocaleString()}</td>
                                    <td><span class="status-badge ${statusClass}">${order.status}</span></td>
                                    <td style="color: #666; font-size: 12px;">${orderDate}</td>
                                </tr>
                            `;
                            tableBody.append(rowHtml);
                        });
                    }
                }).fail(function() {
                    $('#recent-orders-body').html('<tr><td colspan="5" style="text-align: center; color: red;">Lost connection to live database. Retrying...</td></tr>');
                });
            }

            fetchLiveSalesData();
            setInterval(fetchLiveSalesData, 10000);
        });
    </script>
</body>
</html>